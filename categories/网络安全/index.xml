width="1706"
height="1279"
srcset="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc2_2_hu8705883669154433653.png 480w, https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc2_2_hu7952245374788092403.png 1024w"
loading="lazy"
alt="misc2_2"
class="gallery-image"
data-flex-grow="133"
data-flex-basis="320px"
>&lt;/p>
&lt;p>&lt;code>geek{Amazing}&lt;/code>&lt;/p>
&lt;h3 id="misc3">misc3
&lt;/h3>&lt;p>&lt;img src="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc3_1.png"
width="1611"
height="937"
srcset="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc3_1_hu1393974999765817317.png 480w, https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc3_1_hu13596937491369835350.png 1024w"
loading="lazy"
alt="misc3_1"
class="gallery-image"
