&lt;h3 id="misc4">misc4
&lt;/h3>&lt;p>&lt;img src="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc4.jpg"
width="1080"
height="1080"
srcset="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc4_hu13591414652916174773.jpg 480w, https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc4_hu12735305196860009024.jpg 1024w"
