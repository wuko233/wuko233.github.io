width="1885"
height="361"
srcset="https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc1_1_hu7871839201506083490.png 480w, https://blog.wuko.top/posts/2024/10/30/newbiectf.html/misc1_1_hu6025428871597820838.png 1024w"
loading="lazy"
alt="misc1_1"
class="gallery-image"
data-flex-grow="522"
data-flex-basis="1253px"
>&lt;/p>
